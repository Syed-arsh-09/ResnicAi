# ResnicAI Configuration Template
# Copy this file to .env and fill in your keys

# Google Gemini API Key (Required for LLM)
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Serper API Key (Optional, for Google search tool)
# Get one from: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# Enable tracing for detailed agent logs
CREWAI_TRACING_ENABLED=true
